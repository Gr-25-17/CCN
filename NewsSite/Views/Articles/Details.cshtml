@model NewsSite.Models.Entities.Article

@{
    ViewData["Title"] = Model.Title;
    bool hasLiked = ViewBag.HasLiked ?? false;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="mb-3">
                <span class="badge bg-primary">@Model.Category?.Name</span>
            </div>

            <h1 class="display-5 fw-bold mb-3">@Model.Title</h1>

            <div class="d-flex justify-content-between align-items-center text-muted mb-4 border-bottom pb-3">
                <small>Published: @Model.CreatedAt.ToString("MMMM dd, yyyy")</small>
                
                <div class="d-flex align-items-center gap-3">
                    <span title="Visningar">👁️ @Model.ViewsCount</span>
                    
                    <form asp-action="ToggleLike" method="post" class="m-0" id="likeForm">
                        <input type="hidden" name="articleId" value="@Model.Id" />
                        <input type="hidden" name="slug" value="@Model.Slug" />
                        
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <button type="submit" id="likeBtn" class="btn btn-sm @(hasLiked ? "btn-danger" : "btn-outline-danger")">
                                ❤️ <span id="likesCountText">@Model.LikesCount</span>
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary" disabled>
                                ❤️ @Model.LikesCount
                            </button>
                        }
                    </form>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="mb-4">
                    <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm" alt="@Model.Title"
                         style="width: 100%; max-height: 400px; object-fit: cover;">
                </div>
            }

            <div class="article-content fs-5 lh-lg mb-5">
                @if (ViewBag.IsLocked)
                {
                    <div class="mb-4 text-muted fst-italic">
                        <p>@Model.Summary</p>
                    </div>
                    
                    <div class="card border-warning shadow-lg text-center p-4 mx-auto mb-5 paywall-card" style="max-width: 500px; background-color: #fffdf5;">
                        <h4 class="text-warning fw-bold mb-3">
                            ⭐ Lås upp artikeln
                        </h4>
                        <p class="text-muted mb-4">
                            Den här artikeln är exklusiv för prenumeranter. Bli medlem idag för att läsa vidare och få tillgång till allt premiuminnehåll!
                        </p>
                        
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-warning btn-lg fw-bold w-100 mb-3 shadow-sm px-5">
                            Bli Prenumerant – 99 kr/mån
                        </a>
                        
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <div class="border-top pt-3 mt-1">
                                <small class="text-muted">Du är inloggad, men saknar en aktiv prenumeration.</small>
                            </div>
                        }
                        else
                        {
                            <div class="border-top pt-3 mt-1">
                                <small class="text-muted">
                                    Redan prenumerant? <a asp-area="Identity" asp-page="/Account/Login" class="text-primary fw-bold text-decoration-none">Logga in här</a>
                                </small>
                            </div>
                        }
                    </div>
                }
                else
                {
                    @Html.Raw(Model.Content)
                }
            </div>
            
            <hr />
            <div class="mb-5 mt-4">
                <button type="button" onclick="navigateBack()" class="btn btn-outline-secondary">← Tillbaka</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function navigateBack() {
            const referrer = document.referrer;
            const currentHost = window.location.hostname;

            if (referrer && referrer.includes(currentHost)) {
                window.history.back();
            } else {
                window.location.href = '/';
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            const likeForm = document.getElementById("likeForm");
            
            if (likeForm) {
                likeForm.addEventListener("submit", async function (e) {
                    e.preventDefault();
                    
                    const btn = document.getElementById("likeBtn");
                    const countText = document.getElementById("likesCountText");
                    const formData = new FormData(likeForm);
                    
                    try {
                        const response = await fetch(likeForm.action, {
                            method: "POST",
                            body: formData
                        });
                        
                        if (response.ok) {
                            const data = await response.json();
                            
                            if (data.success) {
                                countText.innerText = data.likesCount;
                                
                                if (data.isLiked) {
                                    btn.classList.remove("btn-outline-danger");
                                    btn.classList.add("btn-danger");
                                } else {
                                    btn.classList.remove("btn-danger");
                                    btn.classList.add("btn-outline-danger");
                                }
                            }
                        }
                    } catch (error) {
                        console.error(error);
                    }
                });
            }
        });
    </script>
}