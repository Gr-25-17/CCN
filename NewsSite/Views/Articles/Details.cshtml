@model NewsSite.Models.Entities.Article

@{
    ViewData["Title"] = Model.Title;
    bool hasLiked = ViewBag.HasLiked ?? false;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="mb-3">
                <span class="badge bg-primary">@Model.Category?.Name</span>
                @if (Model.IsPremium)
                {
                    <span class="badge bg-warning text-dark">⭐ Premium</span>
                }
            </div>

            <h1 class="display-5 fw-bold mb-3">@Model.Title</h1>

            <div class="d-flex justify-content-between align-items-center text-muted mb-4 border-bottom pb-3">
                <small>Skriven av @Model.AuthorName | @Model.CreatedAt.ToString("yyyy-MM-dd")</small>
                
                <div class="d-flex align-items-center gap-3">
                    <span title="Visningar">👁️ @Model.ViewsCount</span>
                    
                    <form asp-action="ToggleLike" method="post" class="m-0" id="likeForm">
                        <input type="hidden" name="articleId" value="@Model.Id" />
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <button type="submit" id="likeBtn" class="btn btn-sm @(hasLiked ? "btn-danger" : "btn-outline-danger")">
                                ❤️ <span id="likesCountText">@Model.LikesCount</span>
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary" disabled>
                                ❤️ @Model.LikesCount
                            </button>
                        }
                    </form>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="mb-4">
                    <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm" alt="@Model.Title"
                         style="width: 100%; max-height: 450px; object-fit: cover;">
                </div>
            }

            <div class="article-body fs-5 lh-lg mb-5">
                @if (ViewBag.IsLocked)
                {
                    <div class="mb-4 text-muted fst-italic border-start border-4 border-warning ps-3">
                        <p>@Model.Summary</p>
                    </div>
                    
                    <div class="position-relative mb-5" style="max-height: 300px; overflow: hidden;">
                        
                        @Html.Raw(Model.Content)
                        
                        <div class="position-absolute bottom-0 start-0 w-100"
                             style="height: 150px; background: linear-gradient(to bottom, rgba(255,255,255,0) 0%, rgba(255,255,255,1) 100%); pointer-events: none;">
                        </div>
                    </div>
                    
                    <div class="card border-warning shadow-lg text-center p-4 mx-auto" style="max-width: 550px; background-color: #fffdf5;">
                        <div class="card-body">
                            <h3 class="card-title text-warning fw-bold mb-3">⭐ Lås upp hela artikeln</h3>
                            <p class="card-text text-muted mb-4">
                                Du har läst ditt gratis smakprov. Som prenumerant får du obegränsad tillgång till all vår journalistik och exklusiva reportage.
                            </p>
                            
                            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-warning btn-lg fw-bold w-100 mb-3 shadow-sm px-5">
                                Bli Prenumerant – 99 kr/mån
                            </a>
                            
                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                <div class="border-top pt-3 mt-2">
                                    <small class="text-muted">Inloggad som @User.Identity.Name. Saknar aktiv prenumeration.</small>
                                </div>
                            }
                            else
                            {
                                <div class="border-top pt-3 mt-2">
                                    <p class="mb-0 text-muted">
                                        Redan prenumerant? <a asp-area="Identity" asp-page="/Account/Login" class="text-primary fw-bold text-decoration-none">Logga in här</a>
                                    </p>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="mb-4 fw-bold">
                        <p>@Model.Summary</p>
                    </div>
                    @Html.Raw(Model.Content)
                }
            </div>
            
            <hr />
            <div class="mb-5 mt-4">
                <button type="button" onclick="navigateBack()" class="btn btn-outline-secondary">← Tillbaka</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function navigateBack() {
            if (document.referrer && document.referrer.includes(window.location.hostname)) {
                window.history.back();
            } else {
                window.location.href = '/';
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            const likeForm = document.getElementById("likeForm");
            if (likeForm) {
                likeForm.addEventListener("submit", async function (e) {
                    e.preventDefault();
                    const btn = document.getElementById("likeBtn");
                    const countText = document.getElementById("likesCountText");
                    const formData = new FormData(likeForm);
                    
                    try {
                        const response = await fetch(likeForm.action, {
                            method: "POST",
                            body: formData
                        });
                        
                        if (response.ok) {
                            const data = await response.json();
                            if (data.success) {
                                countText.innerText = data.likesCount;
                                if (data.isLiked) {
                                    btn.classList.replace("btn-outline-danger", "btn-danger");
                                } else {
                                    btn.classList.replace("btn-danger", "btn-outline-danger");
                                }
                            }
                        }
                    } catch (error) {
                        console.error("Gick inte att gilla:", error);
                    }
                });
            }
        });
    </script>
}