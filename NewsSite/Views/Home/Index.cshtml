@model NewsSite.Models.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Home";
}

<div class="container">
    <div class="row">
        <div class="col-md-8">
            @* Show search results if in search mode *@
            @if (Model.IsSearch)
            {
                <h2 class="mb-4">Sökresultat för "@Model.SearchTerm"</h2>

                @if (Model.SearchResults.Any())
                {
                    <div class="row">
                        @foreach (var article in Model.SearchResults)
                        {
                            <div class="col-12 mb-4">
                                <partial name="Partials/_SearchResult" model="article" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-info">Inga artiklar hittades för "@Model.SearchTerm".</div>
                }
            }
            else
            {
                @* Show prioritized articles if user has preferences *@
                @if (Model.PrioritizedArticles.Any())
                {
                    <div class="mb-5">
                        <h2 class="mb-3">Personliga favoriter</h2>
                        <div class="row">
                            @foreach (var article in Model.PrioritizedArticles)
                            {
                                <div class="col-md-3 mb-3">
                                    <partial name="Partials/_ArticleCard" model="article" />
                                </div>
                            }
                        </div>
                        <hr />
                    </div>
                }

                @* Show latest articles *@
                <h2 class="mb-4">Senaste nytt</h2>

                @if (Model.LatestArticles.Any())
                {
                    <div class="row">
                        @foreach (var article in Model.LatestArticles)
                        {
                            <div class="col-12 mb-4">
                                <partial name="Partials/_ArticleCard" model="article" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-info">Inga artiklar ännu. Kom tillbaka senare!</div>
                }
            }
        </div>

        <div class="col-md-4">
            
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-warning">
                    <strong>⭐ Editor's Choice</strong>
                </div>
                <div class="card-body">
                    @if (!Model.EditorChoiceArticles.Any())
                    {
                        <p class="text-muted">No featured articles yet.</p>
                    }
                    else
                    {
                        @foreach (var article in Model.EditorChoiceArticles)
                        {
                            <div class="mb-3">
                                <h6>
                                    <a asp-controller="Articles" asp-action="Details" asp-route-slug="@article.Slug" class="text-decoration-none">
                                        @article.Title
                                    </a>
                                </h6>
                                    <small class="text-muted">@article.CategoryName</small>
                            </div>
                        }
                    }
                </div>
            </div>

            
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-danger text-white">
                    <strong>🔥 Most Popular</strong>
                </div>
                <div class="card-body">
                    @if (!Model.MostPopularArticles.Any())
                    {
                        <p class="text-muted">No popular articles yet.</p>
                    }
                    else
                    {
                        <ul class="list-unstyled">
                            @foreach (var article in Model.MostPopularArticles.Take(5))
                            {
                                <li class="mb-2">
                                    <a asp-controller="Articles" asp-action="Details" asp-route-slug="@article.Slug" class="text-decoration-none">
                                        @article.Title
                                    </a>
                                    <small class="text-muted d-block">@article.CategoryName</small>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

          
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <strong>📂 Categories</strong>
                </div>
                <div class="card-body">
                    <div class="row">
                        @foreach (var category in Model.Categories)
                        {
                            <div class="col-6 mb-2">
                                <a asp-controller="Category" asp-action="Index" asp-route-slug="@category.Name"
                                   class="btn btn-outline-secondary btn-sm w-100">
                                    @category.Name
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <partial name="Partials/_WeatherCard" model="Model.Weather" />
        </div>
    </div>
</div>


@if (!(User.Identity?.IsAuthenticated ?? false) || !(Model?.HasActiveSubscription ?? false))
{
    <div id="subscribeBanner" class="alert alert-warning shadow-lg mb-0 d-none"
         role="alert"
         style="position: fixed; top: 70px; left: 0; right: 0; margin: 15px; z-index: 1050; border: 2px solid #ffc107;">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="alert-heading mb-1">⭐ Prenumerera nu!</h5>
                    <p class="mb-0 small">Få tillgång till alla premiumartiklar och exklusiva reportage.</p>
                </div>
                <div class="d-flex align-items-center">
                    <button type="button" class="btn btn-dark btn-sm fw-bold me-3" data-bs-toggle="offcanvas" data-bs-target="#subscribeOffcanvas">Prenumerera</button>
                    <button type="button" id="maybeLaterBtn" class="btn btn-outline-secondary btn-sm border-0 text-dark">Kanske senare...</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const isAuthenticated = @(User.Identity.IsAuthenticated ? "true" : "false");
            const banner = document.getElementById('subscribeBanner');
            const dismissBtn = document.getElementById('maybeLaterBtn');
            
            let clickCount = 0;
            const messages = [
                "Click here if you're sure...",
                "No subscription?!!!",
                "NO SUBSCRIPTION!=!?!!!!!!!!!!!!!",
                "Fine.... I wouldn't sell you one anyway..."
            ];


            dismissBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                if (clickCount < messages.length) {
                    dismissBtn.textContent = messages[clickCount];
                    clickCount++;
                } else {
                    hideBanner();
                }
            });

            document.addEventListener('click', function (event) {
                if (!banner.classList.contains('d-none') && !banner.contains(event.target)) {
                    hideBanner();
                }
            });

            function hideBanner() {
                if (!isAuthenticated) {

                    localStorage.setItem('bannerCooldown', Date.now() + (5 * 60 * 1000));
                }
                banner.classList.add('d-none');
                clickCount = 0;
                dismissBtn.textContent = "Kanske senare...";
            }

            function shouldShow() {
                if (isAuthenticated) return true;
                const cooldown = localStorage.getItem('bannerCooldown');
                return !cooldown || Date.now() > parseInt(cooldown);
            }

            function showBanner() {
                if (shouldShow()) {
                    banner.classList.remove('d-none');
                }
            }


            if (isAuthenticated) {
                showBanner();
            } else {
                let triggered = false;
                setTimeout(() => { if (!triggered) { showBanner(); triggered = true; } }, 12000);
                window.addEventListener('scroll', () => {
                    if (triggered) return;
                    const scrollPct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
                    if (scrollPct >= 60) { showBanner(); triggered = true; }
                });
            }
        });
    </script>
}
    }
}