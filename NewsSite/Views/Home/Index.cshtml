@model NewsSite.Models.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Home";
}

<div class="container">
    <div class="row">
        <div class="col-md-8">
            <h2 class="mb-4">Latest News</h2>

            @if (Model.LatestArticles.Any())
            {
                <div class="row">
                    @foreach (var article in Model.LatestArticles)
                    {
                        <div class="col-12 mb-4">
                            <partial name="Partials/_ArticleCard" model="article" />
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">No articles yet. Check back soon!</div>
            }
        </div>

        <div class="col-md-4">
            
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-warning">
                    <strong>⭐ Editor's Choice</strong>
                </div>
                <div class="card-body">
                    @if (!Model.EditorChoiceArticles.Any())
                    {
                        <p class="text-muted">No featured articles yet.</p>
                    }
                    else
                    {
                        @foreach (var article in Model.EditorChoiceArticles)
                        {
                            <div class="mb-3">
                                <h6>
                                    <a asp-controller="Articles" asp-action="Details" asp-route-slug="@article.Slug" class="text-decoration-none">
                                        @article.Title
                                    </a>
                                </h6>
                                <small class="text-muted">@article.Category?.Name</small>
                            </div>
                        }
                    }
                </div>
            </div>

            
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-danger text-white">
                    <strong>🔥 Most Popular</strong>
                </div>
                <div class="card-body">
                    @if (!Model.MostPopularArticles.Any())
                    {
                        <p class="text-muted">No popular articles yet.</p>
                    }
                    else
                    {
                        <ul class="list-unstyled">
                            @foreach (var article in Model.MostPopularArticles.Take(5))
                            {
                                <li class="mb-2">
                                    <a asp-controller="Articles" asp-action="Details" asp-route-slug="@article.Slug" class="text-decoration-none">
                                        @article.Title
                                    </a>
                                    <small class="text-muted d-block">@article.Category?.Name</small>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

          
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <strong>📂 Categories</strong>
                </div>
                <div class="card-body">
                    <div class="row">
                        @foreach (var category in Model.Categories)
                        {
                            <div class="col-6 mb-2">
                                <a asp-controller="Category" asp-action="Index" asp-route-slug="@category.Name"
                                   class="btn btn-outline-secondary btn-sm w-100">
                                    @category.Name
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@if (!User.Identity.IsAuthenticated || !Model.HasActiveSubscription)
{
    <div class="modal fade" id="subscribeModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Subscribe Now!!!</h5>

                </div>
                <div class="modal-body">
                    <p>BUY SUBSCRIPTION NOW OR LATER!?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" id="maybeLaterBtn">Later</button>
                    <a href="#" class="btn btn-primary">Subscribe</a>
                </div>
            </div>
        </div>
    </div>


    // kan ta bort delar eller hela
<script>
    window.onload = function () {
    var modal = new bootstrap.Modal(document.getElementById('subscribeModal'));
    modal.show();

    var clicks = 0;
    var btn = document.getElementById('maybeLaterBtn');

        btn.addEventListener('click', function () {
        clicks++;
        if (clicks == 1) {
            btn.textContent = "Click here if you're sure you don't to buy subscription.";
            } else if (clicks == 2) {
                btn.textContent = "No subscription?!!!";
            } else if (clicks == 3) {
                btn.textContent = "NO SUBSCRIPTION!=!?!!!!!!!!!!!!!";
            } else if (clicks == 4) {
                btn.textContent = "Fine.... I wouldn't sell you a subscription anyway...'";
            } else {
                modal.hide();
            }
        });
        }
    </script>
}