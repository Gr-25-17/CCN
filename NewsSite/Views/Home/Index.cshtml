@model NewsSite.Models.ViewModels.HomeViewModel
@using NewsSite.Models.ViewModels

@{
    ViewData["Title"] = "Home";
    var shouldShowSubscriptionBanner = !Model.HasActiveSubscription &&
                                       (!(User.Identity?.IsAuthenticated ?? false) || User.IsInRole("Reader"));
}

<style>
    .hero-carousel {
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        margin-bottom: 2rem;
    }

    .carousel-item {
        height: 500px;
        position: relative;
    }

    .carousel-item picture,
    .carousel-item picture img {
        width: 100%;
        height: 100%;
    }

    .carousel-item picture img {
        object-fit: cover;
    }

    .carousel-item::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 100%);
        z-index: 1;
    }

    .carousel-caption {
        bottom: 20%;
        text-align: left;
        left: 10%;
        right: auto;
        z-index: 2;
    }
</style>

<div class="container">
    @if (Model.LatestArticles.Take(5).Any())
    {
        <div class="hero-carousel">
            <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">
                <div class="carousel-indicators">
                    @for (int i = 0; i < Model.LatestArticles.Take(5).Count(); i++)
                    {
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")"></button>
                    }
                </div>
                <div class="carousel-inner">
                    @foreach (var (article, index) in Model.LatestArticles.Take(5).Select((a, i) => (a, i)))
                    {
                        <div class="carousel-item @(index == 0 ? "active" : "")">
                            <partial name="Partials/_ResponsiveImage"
                                     model="new ResponsiveImageViewModel { ImageUrl = article.ImageUrl, Alt = article.Title, Size = \"full\", Loading = index == 0 ? \"eager\" : \"lazy\" }" />
                            <div class="carousel-caption">
                                <span class="category-badge">@article.CategoryName</span>
                                <h2>@article.Title</h2>
                                <p>@(article.Summary?.Length > 120 ? article.Summary.Substring(0, 120) + "..." : article.Summary)</p>
                                <a asp-controller="Articles" asp-action="Details" asp-route-slug="@article.Slug" class="btn btn-light btn-lg rounded-pill px-4">Read More →</a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            @if (Model.IsSearch)
            {
                <h2 class="section-title">🔍 Search Results for "@Model.SearchTerm"</h2>
                @if (Model.SearchResults.Any())
                {
                    <div class="row">
                        @foreach (var article in Model.SearchResults)
                        {
                            <div class="col-12 mb-4">
                                <div class="card latest-card">
                                    <div class="row g-0">
                                        <div class="col-md-4">
                                            <partial name="Partials/_ResponsiveImage"
                                                     model="new ResponsiveImageViewModel { ImageUrl = article.ImageUrl, Alt = article.Title, Size = \"med\", CssClass = \"card-img h-100 w-100\", Style = \"object-fit: cover;\" }" />
                                        </div>
                                        <div class="col-md-8"><div class="card-body"><h5 class="card-title"><a asp-controller="Articles" asp-action="Details" asp-route-slug="@article.Slug" class="text-decoration-none text-dark">@article.Title</a></h5></div></div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                @if (Model.PrioritizedArticles.Any())
                {
                    <div class="mb-5">
                        <h2 class="section-title">🎯 Based on Your Preferences</h2>
                        <div class="row g-3">
                            @foreach (var article in Model.PrioritizedArticles.Take(4))
                            {
                                <div class="col-md-6 col-lg-6">
                                    <div class="card preference-card h-100">
                                        <partial name="Partials/_ResponsiveImage"
                                                 model="new ResponsiveImageViewModel { ImageUrl = article.ImageUrl, Alt = article.Title, Size = \"med\", CssClass = \"card-img-top\" }" />
                                        <div class="card-body"><small class="text-muted">@article.CategoryName</small><h5 class="card-title">@article.Title</h5></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div>
                    <h2 class="section-title">📰 Latest News</h2>
                    @foreach (var article in Model.LatestArticles)
                    {
                        <div class="card latest-card">
                            <div class="row g-0">
                                <div class="col-md-4">
                                    <partial name="Partials/_ResponsiveImage"
                                             model="new ResponsiveImageViewModel { ImageUrl = article.ImageUrl, Alt = article.Title, Size = \"med\", CssClass = \"card-img h-100 w-100\", Style = \"object-fit: cover;\" }" />
                                </div>
                                <div class="col-md-8"><div class="card-body"><span class="badge bg-primary rounded-pill">@article.CategoryName</span><h5 class="card-title"><a asp-controller="Articles" asp-action="Details" asp-route-slug="@article.Slug" class="text-decoration-none text-dark">@article.Title</a></h5></div></div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-lg-4">
            <partial name="Partials/_WeatherCard" model="Model.Weather" />
        </div>
    </div>
</div>

@if (!(User.Identity?.IsAuthenticated ?? false) || !(Model?.HasActiveSubscription ?? false))
{
    <div id="subscribeBanner" class="alert alert-warning shadow-lg mb-0 d-none" role="alert" style="position: fixed; top: 70px; left: 0; right: 0; margin: 15px; z-index: 1050; border: 2px solid #ffc107; border-radius: 12px;">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="alert-heading mb-1"><i class="bi bi-gem"></i> Subscribe Now!</h5>
                    <p class="mb-0 small">Get access to all premium articles and exclusive reports.</p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button type="button" id="subscribeBannerButton" class="btn btn-dark btn-sm fw-bold" data-bs-toggle="offcanvas" data-bs-target="#loginOffcanvas" data-auth-mode="subscribe"><i class="bi bi-trophy"></i>Prenumerera</button>
                    <button type="button" id="maybeLaterBtn" class="btn btn-outline-secondary btn-sm border-0">Kanske senare...</button>
                </div>
            </div>
        </div>
    </div>
}
