@model NewsSite.Models.ViewModels.UserAdminViewModel
@{
    var activeUsers = Model.Users.Where(u => !u.IsDeleted).OrderBy(u => u.CurrentRole).ThenBy(u => u.FullName).ToList();
    var deletedUsers = Model.Users.Where(u => u.IsDeleted).OrderBy(u => u.FullName).ToList();
    var admins = activeUsers.Where(u => string.Equals(u.CurrentRole, "Admin", StringComparison.OrdinalIgnoreCase)).ToList();
    var editors = activeUsers.Where(u => string.Equals(u.CurrentRole, "Editor", StringComparison.OrdinalIgnoreCase)).ToList();
    var writers = activeUsers.Where(u => string.Equals(u.CurrentRole, "Writer", StringComparison.OrdinalIgnoreCase)).ToList();
    var others = activeUsers.Where(u => !string.Equals(u.CurrentRole, "Admin", StringComparison.OrdinalIgnoreCase) && !string.Equals(u.CurrentRole, "Editor", StringComparison.OrdinalIgnoreCase) && !string.Equals(u.CurrentRole, "Writer", StringComparison.OrdinalIgnoreCase)).ToList();
}

<div class="container-fluid px-4 mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <h2 class="mb-3 mb-md-0">Användaradministration</h2>
        <div class="badge bg-primary p-2">Totalt: @Model.Users.Count användare</div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <ul class="nav nav-tabs" id="adminTabs" role="tablist">
        <li class="nav-item" role="presentation"><button class="nav-link active" id="users-tab" data-bs-toggle="tab" data-bs-target="#users-pane" type="button" role="tab">Användare</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" id="analytics-tab" data-bs-toggle="tab" data-bs-target="#analytics-pane" type="button" role="tab">Analytics</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" id="tools-tab" data-bs-toggle="tab" data-bs-target="#tools-pane" type="button" role="tab">Systemverktyg</button></li>
    </ul>

    <div class="tab-content pt-3">
        <div class="tab-pane fade show active" id="users-pane" role="tabpanel" aria-labelledby="users-tab">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <form asp-action="Index" method="get" class="row g-2 align-items-end">
                        <div class="col-md-4"><label class="form-label" for="search">Sök</label><input id="search" name="search" value="@Model.Search" class="form-control" placeholder="Namn eller e-post" /></div>
                        <div class="col-md-3"><label class="form-label" for="roleFilter">Roll</label><select id="roleFilter" name="roleFilter" class="form-select"><option value="">Alla</option>@foreach (var role in Model.AvailableRoles){<option value="@role.Value" selected="@(role.Value == Model.RoleFilter)">@role.Text</option>}</select></div>
                        <div class="col-md-3"><label class="form-label" for="isDeletedFilter">Status</label><select id="isDeletedFilter" name="isDeletedFilter" class="form-select"><option value="">Alla</option><option value="false" selected="@(Model.IsDeletedFilter == false)">Aktiv</option><option value="true" selected="@(Model.IsDeletedFilter == true)">Borttagen</option></select></div>
                        <div class="col-md-2 d-grid"><button type="submit" class="btn btn-primary">Filtrera</button></div>
                    </form>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Admin</div><div class="h4 mb-0">@admins.Count</div></div></div></div>
                <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Editor</div><div class="h4 mb-0">@editors.Count</div></div></div></div>
                <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Writer</div><div class="h4 mb-0">@writers.Count</div></div></div></div>
                <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Övriga aktiva</div><div class="h4 mb-0">@others.Count</div></div></div></div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white py-3"><h5 class="card-title mb-0">Aktiva användare (sorterad per roll, namn)</h5></div>
                <div class="card-body p-0">@await Html.PartialAsync("_AdminUserTable", activeUsers)</div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white py-3"><h5 class="card-title mb-0">Inaktiverade användare</h5></div>
                <div class="card-body p-0">@await Html.PartialAsync("_AdminUserTable", deletedUsers)</div>
            </div>
        </div>

        <div class="tab-pane fade" id="analytics-pane" role="tabpanel" aria-labelledby="analytics-tab">
            <div id="errorBox" class="alert alert-danger d-none" role="alert"></div>
            <div id="statsContainer" class="row g-3"></div>
        </div>

        <div class="tab-pane fade" id="tools-pane" role="tabpanel" aria-labelledby="tools-tab">
            <div class="card shadow-sm border-warning mb-4"><div class="card-body"><h5 class="card-title text-warning"><i class="bi bi-exclamation-triangle"></i> Systemverktyg: Bildmigrering</h5><p class="card-text text-muted">Kör detta skript för att konvertera alla gamla bilder i databasen till den nya WebP-arkitekturen.</p>@Html.AntiForgeryToken()<button id="btnMigrate" class="btn btn-warning" onclick="startMigration()">Kör migrering nu</button><div id="migrationFeedback" class="mt-3 d-none align-items-center"><div class="spinner-border spinner-border-sm text-warning me-2" role="status"></div><span id="migrationStatus" class="fw-bold text-secondary">Startar migrering... Detta kan ta flera minuter.</span></div></div></div>
            <div class="card shadow-sm border-danger mb-4"><div class="card-body"><h5 class="card-title text-danger"><i class="bi bi-database-up"></i> Systemverktyg: Datamigrering till extern SQL Server</h5><p class="card-text text-muted">Kör en engångsmigrering av lokal SQLite-data till extern SQL Server (LexiconConnection).</p><form asp-action="RunLocalToLexiconMigration" method="post" onsubmit="return confirm('Vill du starta datamigrering till extern SQL Server nu?');" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="btn btn-danger">Kör datamigrering nu</button></form></div></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-operations.js" asp-append-version="true"></script>
}
