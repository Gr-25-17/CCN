@model NewsSite.Models.ViewModels.UserAdminViewModel
@using Microsoft.AspNetCore.Mvc.ViewFeatures
@{
    var staffRoleNames = new[] { "Admin", "Editor", "Writer" };
    var staffUsers = Model.Users.Where(u => staffRoleNames.Contains(u.CurrentRole, StringComparer.OrdinalIgnoreCase)).ToList();
    var regularUsers = Model.Users.Where(u => !staffRoleNames.Contains(u.CurrentRole, StringComparer.OrdinalIgnoreCase)).ToList();

    var staffActiveUsers = staffUsers.Where(u => !u.IsDeleted).ToList();
    var staffInactiveUsers = staffUsers.Where(u => u.IsDeleted).ToList();
    var regularActiveUsers = regularUsers.Where(u => !u.IsDeleted).ToList();
    var regularInactiveUsers = regularUsers.Where(u => u.IsDeleted).ToList();

    var admins = staffActiveUsers.Where(u => string.Equals(u.CurrentRole, "Admin", StringComparison.OrdinalIgnoreCase)).ToList();
    var editors = staffActiveUsers.Where(u => string.Equals(u.CurrentRole, "Editor", StringComparison.OrdinalIgnoreCase)).ToList();
    var writers = staffActiveUsers.Where(u => string.Equals(u.CurrentRole, "Writer", StringComparison.OrdinalIgnoreCase)).ToList();

    var subscribers = regularActiveUsers.Where(u => u.HasActiveSubscription).ToList();
    var nonSubscribers = regularActiveUsers.Where(u => !u.HasActiveSubscription).ToList();

    var staffActiveTableViewData = new ViewDataDictionary(ViewData) { ["TableId"] = "staff-active" };
    var staffInactiveTableViewData = new ViewDataDictionary(ViewData) { ["TableId"] = "staff-inactive" };
    var regularActiveTableViewData = new ViewDataDictionary(ViewData) { ["TableId"] = "regular-active" };
    var regularInactiveTableViewData = new ViewDataDictionary(ViewData) { ["TableId"] = "regular-inactive" };
}

<div class="container-fluid px-4 mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <h2 class="mb-3 mb-md-0">Användaradministration</h2>
        <div class="badge bg-primary p-2">Totalt: @Model.Users.Count användare</div>
    </div>

    <ul class="nav nav-tabs" id="adminTabs" role="tablist">
        <li class="nav-item" role="presentation"><button class="nav-link active" id="users-tab" data-bs-toggle="tab" data-bs-target="#users-pane" type="button" role="tab">Användare</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" id="analytics-tab" data-bs-toggle="tab" data-bs-target="#analytics-pane" type="button" role="tab">Analytics</button></li>
        <li class="nav-item" role="presentation"><button class="nav-link" id="tools-tab" data-bs-toggle="tab" data-bs-target="#tools-pane" type="button" role="tab">Systemverktyg</button></li>
    </ul>

    <div class="tab-content pt-3">
        <div class="tab-pane fade show active" id="users-pane" role="tabpanel" aria-labelledby="users-tab">
            <ul class="nav nav-pills mb-3" role="tablist">
                <li class="nav-item" role="presentation"><button class="nav-link active" data-bs-toggle="pill" data-bs-target="#staff-pane" type="button" role="tab">Personal</button></li>
                <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#regular-pane" type="button" role="tab">Användare</button></li>
            </ul>

            <div class="tab-content">
                <div class="tab-pane fade show active" id="staff-pane" role="tabpanel">
                    <div class="row g-3 mb-3">
                        <div class="col-12 col-sm-6 col-xl-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Admins</div><div class="h4 mb-0">@admins.Count</div></div></div></div>
                        <div class="col-12 col-sm-6 col-xl-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Editors</div><div class="h4 mb-0">@editors.Count</div></div></div></div>
                        <div class="col-12 col-sm-6 col-xl-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Writers</div><div class="h4 mb-0">@writers.Count</div></div></div></div>
                    </div>
                    <div class="card shadow-sm mb-4"><div class="card-header bg-white py-3"><h5 class="card-title mb-0">Aktiv personal</h5></div><div class="card-body p-0">@await Html.PartialAsync("_AdminUserTable", staffActiveUsers, staffActiveTableViewData)</div></div>
                    <div class="card shadow-sm mb-4"><div class="card-header bg-white py-3"><h5 class="card-title mb-0">Inaktiv / Borttagen personal</h5></div><div class="card-body p-0">@await Html.PartialAsync("_AdminUserTable", staffInactiveUsers, staffInactiveTableViewData)</div></div>
                </div>

                <div class="tab-pane fade" id="regular-pane" role="tabpanel">
                    <div class="row g-3 mb-3">
                        <div class="col-12 col-sm-6"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Prenumeranter</div><div class="h4 mb-0">@subscribers.Count</div></div></div></div>
                        <div class="col-12 col-sm-6"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Icke prenumeranter</div><div class="h4 mb-0">@nonSubscribers.Count</div></div></div></div>
                    </div>
                    <div class="card shadow-sm mb-4"><div class="card-header bg-white py-3"><h5 class="card-title mb-0">Aktiva användare (readers + subscribers)</h5></div><div class="card-body p-0">@await Html.PartialAsync("_AdminUserTable", regularActiveUsers, regularActiveTableViewData)</div></div>
                    <div class="card shadow-sm mb-4"><div class="card-header bg-white py-3"><h5 class="card-title mb-0">Inaktiv / Borttagen användare</h5></div><div class="card-body p-0">@await Html.PartialAsync("_AdminUserTable", regularInactiveUsers, regularInactiveTableViewData)</div></div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="analytics-pane" role="tabpanel" aria-labelledby="analytics-tab">@await Html.PartialAsync("_SubscriptionAnalyticsContent")</div>
        <div class="tab-pane fade" id="tools-pane" role="tabpanel" aria-labelledby="tools-tab"></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/admin-analytics.js" asp-append-version="true"></script>
    <script src="~/js/admin-user-sort.js" asp-append-version="true"></script>
    <script src="~/js/admin-operations.js" asp-append-version="true"></script>
}
