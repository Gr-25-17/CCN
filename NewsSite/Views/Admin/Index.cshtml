@model NewsSite.Models.ViewModels.UserAdminViewModel

<div class="container-fluid px-4 mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <h2 class="mb-3 mb-md-0">Användaradministration</h2>
        <div class="badge bg-primary p-2">
            Totalt: @Model.Users.Count användare
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
            <h5 class="card-title mb-0">Systemanvändare</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Namn</th>
                            <th class="d-none d-lg-table-cell">Födelsedatum</th>
                            <th class="d-none d-md-table-cell">E-post</th>
                            <th>Roll</th>
                            <th>Status</th>
                            <th class="text-end">Åtgärder</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr class="@(user.IsDeleted ? "table-light text-muted" : "")">
                                <td>
                                    <div class="fw-bold">@user.FullName</div>
                                    <div class="d-md-none text-muted small">@user.Email</div>
                                </td>
                                <td class="d-none d-lg-table-cell">
                                    @user.DateOfBirth.ToShortDateString()
                                </td>
                                <td class="d-none d-md-table-cell">
                                    @user.Email
                                </td>
                                <td>
                                    <form asp-action="UpdateRole" method="post" class="d-flex gap-2">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <div class="input-group input-group-sm" style="min-width: 140px;">
                                            <select name="newRole" class="form-select" disabled="@user.IsDeleted">
                                                @foreach (var role in Model.AvailableRoles)
                                                {
                                                    <option value="@role.Value" selected="@(role.Value == user.CurrentRole)">
                                                        @role.Text
                                                    </option>
                                                }
                                            </select>
                                            <button type="submit" class="btn btn-primary" disabled="@user.IsDeleted">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </div>
                                    </form>
                                </td>
                                <td>
                                    @if (user.IsDeleted)
                                    {
                                        <span class="badge rounded-pill bg-danger">Borttagen</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-success">Aktiv</span>
                                    }
                                </td>
                                <td class="text-end px-3">
                                    @if (user.IsDeleted)
                                    {
                                        @* Om det är en anonymiserad användare ska vi inte kunna återställa den (GDPR) *@
                                        @if (!user.Email.Contains("@anonymized.com"))
                                        {
                                            <form asp-action="Restore" method="post" class="d-inline">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button type="submit" class="btn btn-sm btn-success">Återställ</button>
                                            </form>
                                        }
                                    }
                                    else
                                    {
                                        <form asp-action="SoftDelete" method="post" onsubmit="return confirm('Inaktivera?');" class="d-inline">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Inaktivera</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<div class="card shadow-sm border-warning mb-4">
    <div class="card-body">
        <h5 class="card-title text-warning"><i class="bi bi-exclamation-triangle"></i> Systemverktyg: Bildmigrering</h5>
        <p class="card-text text-muted">
            Kör detta skript för att konvertera alla gamla bilder i databasen till den nya WebP-arkitekturen.
            Detta körs i bakgrunden. Stäng inte den här fliken förrän processen är klar.
        </p>
        
        <button id="btnMigrate" class="btn btn-warning" onclick="startMigration()">
            Kör migrering nu
        </button>

        <div id="migrationFeedback" class="mt-3 d-none align-items-center">
            <div class="spinner-border spinner-border-sm text-warning me-2" role="status"></div>
            <span id="migrationStatus" class="fw-bold text-secondary">Startar migrering... Detta kan ta flera minuter.</span>
        </div>
    </div>
</div>

<script>
    async function startMigration() {
        const btn = document.getElementById('btnMigrate');
        const feedback = document.getElementById('migrationFeedback');
        const statusText = document.getElementById('migrationStatus');

        btn.disabled = true;
        feedback.classList.replace('d-none', 'd-flex');
        statusText.innerText = "Migrering pågår... vänligen vänta.";
        statusText.className = "fw-bold text-primary";

        try {
            const response = await fetch('/Admin/RunImageMigration', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });

            if (response.ok) {
                statusText.innerText = "Migrering skickad till Azure! Bilderna bearbetas nu i bakgrunden.";
                statusText.className = "fw-bold text-success";
            } else {
                throw new Error("Ett fel uppstod på servern.");
            }
        } catch (error) {
            statusText.innerText = error.message;
            statusText.className = "fw-bold text-danger";
        } finally {
            btn.disabled = false;
        }
    }
</script>

<div class="card shadow-sm border-danger mb-4">
    <div class="card-body">
        <h5 class="card-title text-danger"><i class="bi bi-database-up"></i> Systemverktyg: Datamigrering till extern SQL Server</h5>
        <p class="card-text text-muted">
            Kör en engångsmigrering av lokal SQLite-data till extern SQL Server (LexiconConnection).
            Kör endast när du är säker på att anslutningssträngen är korrekt och målmiljön är redo.
        </p>

        <form asp-action="RunLocalToLexiconMigration" method="post" onsubmit="return confirm('Vill du starta datamigrering till extern SQL Server nu?');" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">Kör datamigrering nu</button>
        </form>
    </div>
</div>
