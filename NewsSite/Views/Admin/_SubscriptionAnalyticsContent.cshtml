<div class="container mt-4 px-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📊 Subscription Analytics</h2>
    </div>

    <div id="errorBox" class="alert alert-danger d-none" role="alert"></div>

    <div id="statsContainer" class="row g-3"></div>

    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <h5 class="mb-4">📈 Subscriber Trend (Last 6 Months)</h5>
            <canvas id="subscriberChart" height="100"></canvas>
        </div>
    </div>

    <hr class="my-4" />

    <h3 class="mb-3">🧑 Writer / Editor Value Snapshot</h3>
    <div id="writerStatsContainer"></div>
</div>
