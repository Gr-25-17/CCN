@model NewsSite.Models.ViewModels.ArticleViewModel

<div class="container mt-4">
    <h2>Redigera artikel</h2>
    <hr />

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImageUrl" />
        
        <div class="row">
            <div class="col-md-8">
                <div class="mb-3">
                    <label asp-for="Title" class="form-label">Titel</label>
                    <input asp-for="Title" class="form-control" id="articleTitle" autocomplete="off" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Slug (genereras automatiskt)</label>
                    <input type="text" class="form-control bg-light" name="Slug" id="articleSlug" readonly tabindex="-1" value="@Model.Slug" />
                </div>

                <div class="mb-3">
                    <label asp-for="Summary" class="form-label">Sammanfattning</label>
                    <textarea asp-for="Summary" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Summary" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Content" class="form-label">Innehåll</label>
                    <textarea asp-for="Content" id="tinyMceEditor"></textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card mb-3">
                    <div class="card-header">Publicering</div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label">Kategori</label>
                            <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select"></select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>
                        
                        <div class="card mb-3 shadow-sm">
                            <div class="card-header bg-light">
                                <strong>Artikelbild</strong>
                            </div>
                            <div class="card-body">
                                <ul class="nav nav-pills mb-3" id="image-tab" role="tablist">
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link active btn-sm" id="pills-upload-tab" data-bs-toggle="pill" data-bs-target="#pills-upload" type="button" role="tab">
                                            Ladda upp fil
                                        </button>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link btn-sm" id="pills-url-tab" data-bs-toggle="pill" data-bs-target="#pills-url" type="button" role="tab">
                                            Klistra in länk
                                        </button>
                                    </li>
                                </ul>
        
                                <div class="tab-content" id="pills-tabContent">
                                    <div class="tab-pane fade show active" id="pills-upload" role="tabpanel">
                                        <div class="mb-2">
                                            <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" id="imageFileInput" />
                                            <span asp-validation-for="ImageFile" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="tab-pane fade" id="pills-url" role="tabpanel">
                                        <div class="mb-2">
                                            <input asp-for="ImageExternalUrl" type="url" class="form-control" placeholder="https://exempel.se/bild.jpg" id="imageUrlInput" />
                                            <span asp-validation-for="ImageExternalUrl" class="text-danger"></span>
                                            <small class="text-muted">Bilden laddas ner och sparas på vår server automatiskt.</small>
                                        </div>
                                    </div>
                                </div>

                                @if (Model.Id != 0 && !string.IsNullOrEmpty(Model.ImageUrl))
                                {
                                    <div class="mt-3 pt-3 border-top">
                                        <small class="text-muted d-block mb-1">Nuvarande bild:</small>
                                        <img src="@Model.ImageUrl" alt="Current Image" class="img-thumbnail" style="max-height: 120px;" />
                                    </div>
                                }
                            </div>
                        </div>



                        
                        @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
                        {
                            <div class="form-check mb-3">
                                <input asp-for="IsPremium" class="form-check-input" />
                                <label asp-for="IsPremium" class="form-check-label">
                                    ⭐ Premiumartikel (Endast prenumeranter)
                                </label>
                            </div>
                            <div class="form-check mb-3">
                                <input asp-for="IsEditorsChoice" class="form-check-input" />
                                <label asp-for="IsEditorsChoice" class="form-check-label">Editor's Choice</label>
                            </div>
                            <div class="form-check mb-3">
                                <input asp-for="IsReadyForPublish" class="form-check-input" />
                                <label asp-for="IsReadyForPublish" class="form-check-label">Redo för publicering</label>
                            </div>
                        }
                        else
                        {
                            <input type="hidden" asp-for="IsPremium" />
                            <input type="hidden" asp-for="IsEditorsChoice" />
                            <input type="hidden" asp-for="IsReadyForPublish" />
                        }

                        <button type="submit" class="btn btn-primary w-100">Spara ändringar</button>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header">SEO Metadata</div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="MetaTitle" class="form-label">Meta Titel</label>
                            <input asp-for="MetaTitle" class="form-control" placeholder="Lämna tom för att använda titel" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="MetaDescription" class="form-label">Meta Beskrivning</label>
                            <textarea asp-for="MetaDescription" class="form-control" rows="3" placeholder="Lämna tom för att använda sammanfattning"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/lib/tinymce/tinymce.min.js"></script>
    <script>
        tinymce.init({
            selector: '#tinyMceEditor',
            license_key: 'gpl',
            height: 500,
            plugins: 'advlist autolink lists link image charmap preview anchor searchreplace visualblocks code fullscreen insertdatetime media table help wordcount',
            toolbar: 'undo redo | formatselect | bold italic backcolor | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | removeformat | help'
        });

        document.getElementById('articleTitle').addEventListener('input', function () {
            let title = this.value;
            let slug = title.toLowerCase()
                .replace(/å/g, 'a')
                .replace(/ä/g, 'a')
                .replace(/ö/g, 'o')
                .replace(/[^a-z0-9\s-]/g, '')
                .replace(/\s+/g, '-')
                .trim();
            
            if (slug.endsWith('-')) {
                slug = slug.slice(0, -1);
            }
            
            document.getElementById('articleSlug').value = slug;
        });
    </script>
}