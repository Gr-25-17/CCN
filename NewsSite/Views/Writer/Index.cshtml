@model IEnumerable<NewsSite.Models.ViewModels.ArticleViewModel>
@{
    var articles = Model.OrderByDescending(a => a.CreatedAt).ToList();
    var readyArticles = articles.Where(a => a.IsReadyForPublish).ToList();
    var draftArticles = articles.Where(a => !a.IsReadyForPublish).ToList();
    var topEngagement = articles.OrderByDescending(a => a.ViewsCount + a.LikesCount).Take(5).ToList();
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Mina Artiklar</h2>
        <a asp-action="Create" class="btn btn-primary">Skapa ny artikel</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Utkast</div><div class="h4 mb-0">@draftArticles.Count</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Redo för publicering</div><div class="h4 mb-0">@readyArticles.Count</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Totalt</div><div class="h4 mb-0">@articles.Count</div></div></div></div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white"><h5 class="mb-0">Utkast (nyast först)</h5></div>
        <div class="card-body p-0">@await Html.PartialAsync("_WriterArticlesTable", draftArticles)</div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white"><h5 class="mb-0">Redo för publicering (nyast först)</h5></div>
        <div class="card-body p-0">@await Html.PartialAsync("_WriterArticlesTable", readyArticles)</div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white"><h5 class="mb-0">Top 5 engagemang (visningar + likes)</h5></div>
        <div class="card-body p-0">@await Html.PartialAsync("_WriterArticlesTable", topEngagement)</div>
    </div>
</div>
