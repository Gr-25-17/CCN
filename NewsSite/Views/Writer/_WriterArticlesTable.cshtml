@model IEnumerable<NewsSite.Models.ViewModels.ArticleViewModel>
@{
    var showCategory = ViewData["ShowCategory"] as bool? ?? true;
    var showStatus = ViewData["ShowStatus"] as bool? ?? true;
}

<div class="table-responsive-custom">
    <table class="table table-hover align-middle mb-0 custom-mobile-table writer-sortable-table">
        <thead class="table-light">
            <tr>
                <th><button type="button" class="btn btn-link p-0 text-decoration-none writer-sort" data-sort="title">Titel</button></th>
                @if (showCategory)
                {
                    <th><button type="button" class="btn btn-link p-0 text-decoration-none writer-sort" data-sort="category">Kategori</button></th>
                }
                @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
                {
                    <th><button type="button" class="btn btn-link p-0 text-decoration-none writer-sort" data-sort="author">Skribent</button></th>
                }
                @if (showStatus)
                {
                    <th><button type="button" class="btn btn-link p-0 text-decoration-none writer-sort" data-sort="status">Status</button></th>
                }
                <th><button type="button" class="btn btn-link p-0 text-decoration-none writer-sort" data-sort="views">Visningar</button></th>
                <th><button type="button" class="btn btn-link p-0 text-decoration-none writer-sort" data-sort="likes">Likes</button></th>
                <th><button type="button" class="btn btn-link p-0 text-decoration-none writer-sort" data-sort="created">Skapad</button></th>
                <th class="text-end">Åtgärder</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="8" class="text-muted p-3">Inga artiklar i denna grupp.</td></tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr data-title="@item.Title" data-category="@item.CategoryName" data-author="@item.AuthorName" data-status="@(item.IsReadyForPublish ? "1" : "0")" data-views="@item.ViewsCount" data-likes="@item.LikesCount" data-created="@item.CreatedAt.Ticks">
                        <td data-label="Titel" class="fw-bold">@item.Title</td>
                        @if (showCategory)
                        {
                            <td data-label="Kategori"><span class="badge bg-secondary">@item.CategoryName</span></td>
                        }
                        @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
                        {
                            <td data-label="Skribent">@item.AuthorName</td>
                        }
                        @if (showStatus)
                        {
                            <td data-label="Status">@if (item.IsReadyForPublish){<span class="badge bg-success">Redo</span>}else{<span class="badge bg-warning text-dark">Utkast</span>}</td>
                        }
                        <td data-label="Visningar">@item.ViewsCount</td>
                        <td data-label="Likes">@item.LikesCount</td>
                        <td data-label="Skapad">@item.CreatedAt.ToShortDateString()</td>
                        <td data-label="Åtgärder" class="text-md-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Redigera</a>
                            @if (!item.IsReadyForPublish)
                            {
                                <form asp-action="DeleteDraft" asp-route-id="@item.Id" method="post" class="d-inline">@Html.AntiForgeryToken()<button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Radera utkastet permanent?');">Radera</button></form>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
