@model NewsSite.Models.Entities.Article

<div class="card h-100 shadow-sm border-0 position-relative">
    @if (Model.IsPremium)
    {
        <div class="position-absolute top-0 end-0 m-2" style="z-index: 10;">
            <span class="badge bg-warning text-dark shadow-sm">
                <i class="bi bi-star-fill me-1"></i> PREMIUM
            </span>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <a asp-controller="Articles" asp-action="Details" asp-route-slug="@Model.Slug">
            <img src="@Model.ImageUrl" class="card-img-top" alt="@Model.Title"
                 style="height: 200px; object-fit: cover; width: 100%;">
        </a>
    }
    
    <div class="card-body d-flex flex-column">
        <div class="mb-2">
            <span class="badge bg-primary">@Model.Category?.Name</span>
        </div>
        
        <h5 class="card-title">
            <a asp-controller="Articles" asp-action="Details" asp-route-slug="@Model.Slug" class="text-decoration-none text-dark fw-bold">
                @Model.Title
            </a>
        </h5>
        
        <p class="card-text text-muted small">
            @Model.Summary
        </p>
        
        <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
            <small class="text-muted">@Model.CreatedAt.ToString("MMM dd, yyyy")</small>
            <div class="text-muted small">
                <span class="me-2">👁️ @Model.ViewsCount</span>
                <span>❤️ @Model.LikesCount</span>
            </div>
        </div>
    </div>
</div>