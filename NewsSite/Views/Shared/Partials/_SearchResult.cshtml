@model NewsSite.Models.ViewModels.SearchArticleVM

<div class="card h-100 shadow-sm @(Model.IsArchived ? "bg-light border-secondary" : "")">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <span class="badge bg-primary">@Model.CategoryName</span>
            <div>
                @if (Model.IsArchived)
                {
                    <span class="badge bg-secondary">Arkiverad</span>
                }
                @if (Model.IsPremium)
                {
                    <span class="badge bg-warning text-dark ms-1">⭐ Premium</span>
                }
            </div>
        </div>

        <h5 class="card-title">
            <a asp-controller="Articles" asp-action="Details" asp-route-slug="@Model.Slug" class="text-decoration-none text-dark fw-bold">
                @Model.Title
            </a>
        </h5>
        
        <p class="card-text text-muted small">@Model.Summary</p>
    </div>
    <div class="card-footer bg-transparent border-0 pb-3">
        <small class="text-muted">@Model.CreatedAt.ToString("yyyy-MM-dd") | Av @Model.AuthorName</small>
    </div>
</div>