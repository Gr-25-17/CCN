@model NewsSite.Models.ViewModels.SearchArticleVM

<div class="card h-100 shadow-sm border-0 position-relative">
    @if (Model.IsPremium)
    {
        <div class="position-absolute top-0 end-0 m-2" style="z-index: 10;">
            <span class="badge bg-warning text-dark shadow-sm">
                <i class="bi bi-star-fill me-1"></i> PREMIUM
            </span>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <a asp-controller="Articles" asp-action="Details" asp-route-slug="@Model.Slug">
            <picture>
                <!-- Om skärmen är väldigt liten (t.ex. mobil i stående läge) ladda 'min' -->
                <source srcset="@Model.ImageUrl.ResolveImageUrl("min", Configuration)" media="(max-width: 576px)">

                <!-- För alla andra (tablets, desktops) ladda 'med' -->
                <img src="@Model.ImageUrl.ResolveImageUrl("med", Configuration)"
                     class="card-img-top"
                     alt="@Model.Title"
                     loading="lazy"
                     decoding="async"
                     style="object-fit: cover; aspect-ratio: 16/9;">
            </picture>
        </a>
    }

    <div class="card-body d-flex flex-column">
        <div class="mb-2">
            <span class="badge bg-primary">@Model.CategoryName</span>
            @if (Model.IsArchived && User.IsInRole("Admin")) // Endast admin kan se arkiverade artiklar i sökresultaten
            {
                <span class="badge bg-secondary ms-1">Arkiverad</span>
            }
        </div>

        <h5 class="card-title">
            <a asp-controller="Articles" asp-action="Details" asp-route-slug="@Model.Slug"
               class="text-decoration-none text-dark fw-bold stretched-link">
                @Model.Title
            </a>
        </h5>

        <p class="card-text text-muted small">
            @Model.Summary
        </p>

        <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
            <small class="text-muted">@Model.CreatedAt.ToString("yyyy-MM-dd") | Av @Model.AuthorName</small>            
            <div class="text-muted small">
                <span class="me-2">👁️ @Model.ViewsCount</span>
                <span>❤️ @Model.LikesCount</span>
            </div>
        </div>
    </div>
</div>