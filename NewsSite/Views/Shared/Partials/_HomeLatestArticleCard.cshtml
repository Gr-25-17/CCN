@model NewsSite.Models.ViewModels.ArticleSummaryViewModel
@{
    const int SummaryMaxLength = 150;
    var summary = Model.Summary?.Length > SummaryMaxLength ? $"{Model.Summary.Substring(0, SummaryMaxLength)}..." : Model.Summary;
}

<div class="card latest-card position-relative">
    @if (Model.IsPremium)
    {
        <div class="position-absolute top-0 end-0 m-2" style="z-index: 10;">
            <span class="badge bg-warning text-dark shadow-sm"><i class="bi bi-star-fill me-1"></i> PREMIUM</span>
        </div>
    }
    <div class="row g-0">
        <div class="col-md-4">
            <a asp-controller="Articles" asp-action="Details" asp-route-slug="@Model.Slug" aria-label="Open @Model.Title">
                <partial name="Partials/_ResponsiveImage"
                         model='new NewsSite.Models.ViewModels.ResponsiveImageViewModel { ImageUrl = Model.ImageUrl, Alt = Model.Title, Size = "med", CssClass = "card-img h-100 w-100", Style = "object-fit: cover;" }' />
            </a>
        </div>
        <div class="col-md-8">
            <div class="card-body position-relative">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="badge bg-primary rounded-pill">@Model.CategoryName</span>
                </div>
                <h5 class="card-title"><a asp-controller="Articles" asp-action="Details" asp-route-slug="@Model.Slug" class="text-decoration-none text-dark stretched-link">@Model.Title</a></h5>
                <p class="card-text">@summary</p>
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted"><i class="bi bi-person"></i> @Model.AuthorName | @Model.CreatedAt.ToString("MMM dd, yyyy")</small>
                    <small class="text-muted"><span class="me-2">👁️ @Model.ViewsCount</span><span>❤️ @Model.LikesCount</span></small>
                </div>
            </div>
        </div>
    </div>
</div>
