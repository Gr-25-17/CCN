@using NewsSite.Models.ViewModels
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@{
    var path = Context.Request.Path.Value ?? string.Empty;
    var isHomePage = path == "/";
    var isPrivacyPage = path.Equals("/Home/Privacy", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NewsSite</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NewsSite.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="@(((User.Identity?.IsAuthenticated ?? false) ? "authenticated " : string.Empty) + (User.IsInRole("Subscriber") ? "has-active-subscription" : string.Empty))">
    <header>
        <nav class="navbar navbar-expand-lg navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">NewsSite</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse" id="mainNavbar">
                    <ul class="navbar-nav me-lg-1 mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index" aria-current="@(isHomePage ? "page" : null)">Home</a>
                        </li>
                        @await Component.InvokeAsync("NavbarCategory")
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy" aria-current="@(isPrivacyPage ? "page" : null)">Privacy</a>
                        </li>
                        @if (!(await AuthorizationService.AuthorizeAsync(User, "PremiumContent")).Succeeded)
                        <li class="nav-item"><a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                       asp-controller="SubscriptionAnalytics"
                                       asp-action="Index">
                                    📊 Analytics
                                </a>
                            </li>
                        }
                        @if (!User.IsInRole("Subscriber"))
                        {
                            <li class="nav-item">
                                <a href="#" class="nav-link text-dark" data-bs-toggle="offcanvas" data-bs-target="#loginOffcanvas" data-auth-mode="subscribe">Subscribe</a>
                            </li>
                        }
                    </ul>
                    <div class="navbar-account">
                        <partial name="_LoginPartial" />
                    </div>
                </div>

                <div class="navbar-utilities d-flex align-items-center ms-lg-2 ms-auto gap-2">
                    <form class="navbar-search d-flex align-items-stretch" asp-controller="Articles" asp-action="Search" method="get">
                        <div class="input-group w-100">
                            <input name="searchTerm" class="form-control" type="search" placeholder="Sök artiklar..." aria-label="Search">
                            <button class="btn btn-primary" type="submit">🔍</button>
                        </div>
                    </form>

                    <div class="d-flex align-items-center navbar-weather">
                        <div id="weatherWidget">@await Component.InvokeAsync("WeatherCardVC", new { detailed = false })</div>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">@RenderBody()</main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">&copy; 2026 - NewsSite - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
            let isDetailed = false;
            async function toggleWeather() {
                isDetailed = !isDetailed;
                const response = await fetch(`/Home/WeatherWidget?detailed=${isDetailed}`);
                const html = await response.text();
                document.getElementById('weatherWidget').innerHTML = html;
            }

            document.addEventListener('DOMContentLoaded', () => {
                const expirationInput = document.querySelector('#subscriptionExpirationDate');
                if (!expirationInput) return;

                const placeholder = 'MM/YY';
                let digits = '';

                const render = () => {
                    const chars = placeholder.split('');
                    for (let i = 0; i < digits.length; i++) {
                        chars[i < 2 ? i : i + 1] = digits[i];
                    }
                    expirationInput.value = chars.join('');
                };

                expirationInput.addEventListener('focus', () => {
                    render();
                    const pos = digits.length < 2 ? digits.length : digits.length + 1;
                    expirationInput.setSelectionRange(pos, pos);
                });

                expirationInput.addEventListener('keydown', (event) => {
                    const isDigit = event.key >= '0' && event.key <= '9';

                    if (isDigit) {
                        event.preventDefault();
                        if (digits.length >= 4) return;

                        const caret = expirationInput.selectionStart ?? 0;
                        const digitIndex = caret <= 2 ? caret : caret - 1;
                        digits = digits.slice(0, digitIndex) + event.key + digits.slice(digitIndex);
                        digits = digits.slice(0, 4);
                        render();

                        const nextIndex = Math.min(digitIndex + 1, digits.length);
                        const nextCaret = nextIndex < 2 ? nextIndex : nextIndex + 1;
                        expirationInput.setSelectionRange(nextCaret, nextCaret);
                        return;
                    }

                    if (event.key === 'Backspace') {
                        event.preventDefault();
                        const caret = expirationInput.selectionStart ?? 0;
                        const digitIndex = caret <= 2 ? caret : caret - 1;
                        if (digitIndex <= 0) return;

                        digits = digits.slice(0, digitIndex - 1) + digits.slice(digitIndex);
                        render();

                        const nextIndex = digitIndex - 1;
                        const nextCaret = nextIndex < 2 ? nextIndex : nextIndex + 1;
                        expirationInput.setSelectionRange(nextCaret, nextCaret);
                        return;
                    }

                    if (event.key === 'Delete') {
                        event.preventDefault();
                        const caret = expirationInput.selectionStart ?? 0;
                        const digitIndex = caret <= 2 ? caret : caret - 1;
                        if (digitIndex >= digits.length) return;

                        digits = digits.slice(0, digitIndex) + digits.slice(digitIndex + 1);
                        render();

                        const nextCaret = digitIndex < 2 ? digitIndex : digitIndex + 1;
                        expirationInput.setSelectionRange(nextCaret, nextCaret);
                        return;
                    }

                    if ([ 'Tab', 'ArrowLeft', 'ArrowRight', 'Home', 'End' ].includes(event.key)) {
                        return;
                    }

                    event.preventDefault();
                });

                render();
            });
    </script>
    @if (TempData["AuthSuccessMessage"] != null)
    {
        <script>
                document.addEventListener('DOMContentLoaded', () => {
                    const offcanvasElement = document.getElementById('loginOffcanvas');
                    if (offcanvasElement) {
                        bootstrap.Offcanvas.getOrCreateInstance(offcanvasElement).show();
                    }
                });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)

    <div class="offcanvas offcanvas-end" tabindex="-1" id="loginOffcanvas" aria-labelledby="loginOffcanvasLabel">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title fw-bold" id="loginOffcanvasLabel">Logga in</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            @await Component.InvokeAsync("LoginFormVC")

            <section id="subscribeView" class="d-none">
                <h4 class="mb-3">Slutför din betalning</h4>
                <p class="text-muted small mb-4">Få omedelbar tillgång till alla premiumartiklar.</p>

                <form asp-controller="Subscription" asp-action="Index" method="post">
                    @Html.AntiForgeryToken()
                    <input name="ReturnUrl" type="hidden" value="@(Context.Request.Path + Context.Request.QueryString)" />

                    <div class="form-floating mb-3">
                        <input id="subscriptionCardName" name="CardName" class="form-control" placeholder="John Doe" required />
                        <label for="subscriptionCardName">Namn på kortet</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input id="subscriptionCardNumber" name="CardNumber" class="form-control" placeholder="1234 5678 9012 3456" required />
                        <label for="subscriptionCardNumber">Kortnummer</label>
                    </div>

                    <div class="row">
                        <div class="col-7 mb-3">
                            <div class="form-floating">
                                <input id="subscriptionExpirationDate" name="ExpirationDate" class="form-control" placeholder="MM/YY" inputmode="numeric" maxlength="5" required />
                                <label for="subscriptionExpirationDate">Giltighetstid</label>
                            </div>
                        </div>
                        <div class="col-5 mb-3">
                            <div class="form-floating">
                                <input id="subscriptionCvv" name="CVV" class="form-control" placeholder="123" inputmode="numeric" maxlength="4" required />
                                <label for="subscriptionCvv">CVV</label>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-warning btn-lg w-100 shadow-sm mt-3 fw-bold">Betala 99 kr / mån</button>
                </form>
            </section>
        </div>
    </div>
</body>
</html>
