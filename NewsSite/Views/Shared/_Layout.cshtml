<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NewsSite</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NewsSite.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">NewsSite</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @await Component.InvokeAsync("NavbarCategory")

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" href="#" data-bs-toggle="offcanvas" data-bs-target="#subscribeOffcanvas">Subscribe</a>
                        </li>
                    </ul>

                    <partial name="_LoginPartial" />
                </div>

                <div class="d-flex align-items-center me-3">
                    <div id="weatherWidget">
                        @await Component.InvokeAsync("WeatherCardVC", new { detailed = false })
                    </div>
                    <button type="button" class="btn btn-sm btn-primary ms-2" onclick="toggleWeather()" title="Toggle weather view">
                        ⇆
                    </button>
                </div>

                <script>
                    let isDetailed = false;
                    async function toggleWeather() {
                        isDetailed = !isDetailed;
                        const response = await fetch(`/Home/WeatherWidget?detailed=${isDetailed}`);
                        const html = await response.text();
                        document.getElementById('weatherWidget').innerHTML = html;
                    }
                </script>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - NewsSite - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <div class="offcanvas offcanvas-end" tabindex="-1" id="loginOffcanvas" aria-labelledby="loginOffcanvasLabel">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title fw-bold" id="loginOffcanvasLabel">Logga in</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            @await Component.InvokeAsync("LoginFormVC")
        </div>
    </div>

    <div class="offcanvas offcanvas-end" tabindex="-1" id="subscribeOffcanvas" aria-labelledby="subscribeOffcanvasLabel">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title fw-bold" id="subscribeOffcanvasLabel">⭐ Prenumerera</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <h4 class="mb-3">Slutför din betalning</h4>
            <p class="text-muted small mb-4">Få omedelbar tillgång till alla premiumartiklar.</p>

            <form asp-controller="Subscription" asp-action="Index" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ReturnUrl" />

                <div class="mb-3">
                    <label class="form-label small fw-bold">Namn på kortet</label>
                    <input name="CardName" class="form-control" placeholder="Förnamn Efternamn" required />
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold">Kortnummer</label>
                    <input name="CardNumber" class="form-control" placeholder="1234 5678 1234 5678" required />
                </div>

                <div class="row">
                    <div class="col-7 mb-3">
                        <label class="form-label small fw-bold">Giltighetstid</label>
                        <input name="ExpirationDate" class="form-control" placeholder="MM/ÅÅ" required />
                    </div>
                    <div class="col-5 mb-3">
                        <label class="form-label small fw-bold">CVV</label>
                        <input name="CVV" class="form-control" placeholder="123" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-warning btn-lg w-100 shadow-sm mt-3 fw-bold">
                    Betala 99 kr / mån
                </button>

                <p class="text-center mt-4 small text-muted">
                    Ingen bindningstid. Avsluta när du vill.
                </p>
            </form>
        </div>
    </div>
</body>
</html>
