@model NewsSite.Models.ViewModels.WeatherViewModel

@if (Model != null)
{
    string bgClass = Model.TemperatureC switch
    {
        < 0 => "bg-primary",
        < 8 => "bg-secondary",
        <= 22 => "bg-success",
        _ => "bg-danger"
    };

    <div class="@bgClass text-white border border-white rounded px-3 py-2" style="font-size:0.85rem; min-width: 200px;">
        <div class="d-flex align-items-center mb-2">
            <img src="@Model.IconUrl" alt="Weather icon" class="me-2" style="width:40px; height:40px;" />
            <div>
                <div><strong>@Model.City</strong></div>
                <div>@Model.TemperatureC.ToString("F1")°C</div>
            </div>
        </div>
        <div class="small">
            <div>💧 Humidity: @Model.Humidity%</div>
            <div>💨 Wind: @Model.WindSpeed m/s</div>
            <div>📅 @Model.Date.ToString("HH:mm")</div>
        </div>
    </div>
}
else
{
    <div class="text-muted small px-2">Weather unavailable</div>
}