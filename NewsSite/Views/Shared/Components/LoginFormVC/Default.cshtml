@using Microsoft.AspNetCore.Identity
@using NewsSite.Models.Entities
@inject SignInManager<ApplicationUser> SignInManager

<section>
    <form asp-area="Identity" asp-page="/Account/Login" method="post" id="loginOffcanvasForm">
        <h3 class="mb-3 fw-bold">Logga in</h3>
        <hr />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-floating mb-3">
            <input name="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
            <label for="Input_Email" class="form-label">Email</label>
            <span class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <input name="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
            <label for="Input_Password" class="form-label">Lösenord</label>
            <span class="text-danger"></span>
        </div>

        <div class="checkbox mb-3">
            <label class="form-label">
                <input class="form-check-input" name="Input.RememberMe" />
                Kom ihåg mig
            </label>
        </div>

        <div>
            <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Logga in</button>
        </div>

        <div class="mt-3">
            <p>
                <a asp-area="Identity" asp-page="/Account/ForgotPassword" class="text-decoration-none">Glömt lösenord?</a>
            </p>
            <p>
                <a asp-area="Identity" asp-page="/Account/Register" class="text-decoration-none">Registrera dig som ny användare</a>
            </p>
            <p>
                <a asp-area="Identity" asp-page="/Account/ResendEmailConfirmation" class="text-decoration-none">Skicka bekräftelse på nytt</a>
            </p>
        </div>
    </form>
</section>
