@using Microsoft.AspNetCore.Identity
@using NewsSite.Models.Entities
@inject SignInManager<ApplicationUser> SignInManager

<section id="authOffcanvasContent">
    <div id="loginView">
        <form id="loginOffcanvasForm">
            <h3 class="mb-3 fw-bold">Logga in</h3>
            <hr />

            <div id="loginErrorAlert" class="alert alert-danger d-none mb-3"></div>
            <div id="loginSuccessAlert" class="alert alert-success d-none mb-3"></div>

            <div class="form-floating mb-3">
                <input id="loginEmail" name="email" type="email" class="form-control" placeholder="name@example.com" />
                <label for="loginEmail">Email</label>
            </div>

            <div class="form-floating mb-3">
                <input id="loginPassword" name="password" type="password" class="form-control" placeholder="password" />
                <label for="loginPassword">Lösenord</label>
            </div>

            <div class="form-check mb-3">
                <input id="rememberMe" type="checkbox" class="form-check-input" />
                <label for="rememberMe" class="form-check-label">Kom ihåg mig</label>
            </div>

            <button id="login-submit" type="button" class="w-100 btn btn-lg btn-primary" onclick="submitLoginForm()">
                Logga in
            </button>

            <div class="mt-3">
                <a href="#" class="text-decoration-none" onclick="showRegisterInLoginOffcanvas(event)">
                    Registrera dig som ny användare
                </a>
            </div>
        </form>
    </div>

    <div id="registerView" class="d-none">
        <form id="registerOffcanvasForm">
            <h3 class="mb-3 fw-bold">Registrera dig</h3>
            <hr />

            <div id="registerErrorAlert" class="alert alert-danger d-none mb-3"></div>
            <div id="registerSuccessAlert" class="alert alert-success d-none mb-3"></div>

            <div class="form-floating mb-3">
                <input id="registerEmail" type="email" class="form-control" placeholder="name@example.com" />
                <label for="registerEmail">Email</label>
            </div>

            <div class="form-floating mb-3">
                <input id="registerPassword" type="password" class="form-control" placeholder="password" />
                <label for="registerPassword">Lösenord</label>
            </div>

            <div class="form-floating mb-3">
                <input id="registerConfirmPassword" type="password" class="form-control" placeholder="password" />
                <label for="registerConfirmPassword">Bekräfta lösenord</label>
            </div>

            <button id="register-submit" type="button" class="w-100 btn btn-lg btn-primary" onclick="submitRegisterForm()">
                Registrera
            </button>

            <div class="mt-3">
                <a href="#" class="text-decoration-none" onclick="showLoginInLoginOffcanvas(event)">
                    Har du redan ett konto? Logga in
                </a>
            </div>
        </form>
    </div>
</section>

<script>
    function showLoginInLoginOffcanvas(event) {
        if (event) event.preventDefault();
        document.getElementById('loginOffcanvasLabel').textContent = 'Logga in';
        document.getElementById('loginView').classList.remove('d-none');
        document.getElementById('registerView').classList.add('d-none');
    }

    function showRegisterInLoginOffcanvas(event) {
        if (event) event.preventDefault();
        document.getElementById('loginOffcanvasLabel').textContent = 'Registrera dig';
        document.getElementById('loginView').classList.add('d-none');
        document.getElementById('registerView').classList.remove('d-none');
    }

    async function submitLoginForm() {
        await submitAuthForm('/api/accountapi/login', {
            email: document.getElementById('loginEmail').value.trim(),
            password: document.getElementById('loginPassword').value,
            rememberMe: document.getElementById('rememberMe').checked
        }, 'login');
    }

    async function submitRegisterForm() {
        await submitAuthForm('/api/accountapi/register', {
            email: document.getElementById('registerEmail').value.trim(),
            password: document.getElementById('registerPassword').value,
            confirmPassword: document.getElementById('registerConfirmPassword').value
        }, 'register');
    }

    async function submitAuthForm(url, payload, mode) {
        const errorAlert = document.getElementById(`${mode}ErrorAlert`);
        const successAlert = document.getElementById(`${mode}SuccessAlert`);
        const submitButton = document.getElementById(`${mode}-submit`);

        errorAlert.classList.add('d-none');
        successAlert.classList.add('d-none');

        submitButton.disabled = true;

        try {
            const response = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            const data = await response.json();

            if (!response.ok) {
                errorAlert.textContent = data.error || 'Ett fel uppstod.';
                errorAlert.classList.remove('d-none');
                return;
            }

            successAlert.textContent = data.message || 'Klart.';
            successAlert.classList.remove('d-none');

            setTimeout(() => {
                const element = document.getElementById('loginOffcanvas');
                const instance = bootstrap.Offcanvas.getInstance(element);
                if (instance) {
                    instance.hide();
                }
                window.location.reload();
            }, 500);
        }
        catch {
            errorAlert.textContent = 'Ett fel uppstod. Försök igen senare.';
            errorAlert.classList.remove('d-none');
        }
        finally {
            submitButton.disabled = false;
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        const loginOffcanvas = document.getElementById('loginOffcanvas');
        if (!loginOffcanvas) return;

        loginOffcanvas.addEventListener('show.bs.offcanvas', event => {
            const trigger = event.relatedTarget;
            const mode = trigger?.getAttribute('data-auth-mode') || 'login';

            if (mode === 'register') {
                showRegisterInLoginOffcanvas();
            } else {
                showLoginInLoginOffcanvas();
            }
        });

        loginOffcanvas.addEventListener('hidden.bs.offcanvas', () => {
            showLoginInLoginOffcanvas();
        });
    });
</script>
