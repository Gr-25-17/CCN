@model NewsSite.Models.ViewModels.HomeSidebarViewModel

<div class="card side-card shadow-sm border-0">
    <div class="card-header" style="background: linear-gradient(135deg, #ffc107, #ff9800);">
        <strong><i class="bi bi-star-fill"></i> Editor's Choice</strong>
    </div>
    <div class="card-body">
        @if (!Model.EditorChoiceArticles.Any())
        {
            <p class="text-muted text-center py-3">No featured articles yet.</p>
        }
        else
        {
            @foreach (var article in Model.EditorChoiceArticles)
            {
                <article class="mb-3 pb-2 border-bottom">
                    <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
                        <h6 class="mb-0 pe-2">
                            <a asp-controller="Articles" asp-action="Details" asp-route-slug="@article.Slug" class="text-decoration-none text-dark fw-semibold">@article.Title</a>
                        </h6>
                        @if (article.IsPremium)
                        {
                            <span class="badge rounded-pill text-bg-warning text-dark flex-shrink-0"><i class="bi bi-gem me-1"></i>Premium</span>
                        }
                    </div>
                    <div class="small text-muted d-flex flex-wrap gap-2">
                        <span class="badge bg-primary rounded-pill">@article.CategoryName</span>
                        <span><i class="bi bi-person me-1"></i>@article.AuthorName</span>
                        <span><i class="bi bi-calendar3 me-1"></i>@article.CreatedAt.ToString("MMM d, yyyy")</span>
                    </div>
                </article>
            }
        }
    </div>
</div>

<div class="card side-card shadow-sm border-0">
    <div class="card-header" style="background: linear-gradient(135deg, #dc3545, #c82333); color: white;">
        <strong><i class="bi bi-fire"></i> Most Popular</strong>
    </div>
    <div class="card-body">
        @if (!Model.MostPopularArticles.Any())
        {
            <p class="text-muted text-center py-3">No popular articles yet.</p>
        }
        else
        {
            @foreach (var article in Model.MostPopularArticles.Take(5))
            {
                <article class="mb-3 pb-2 border-bottom">
                    <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
                        <h6 class="mb-0 pe-2">
                            <a asp-controller="Articles" asp-action="Details" asp-route-slug="@article.Slug" class="text-decoration-none text-dark fw-semibold">@article.Title</a>
                        </h6>
                        @if (article.IsPremium)
                        {
                            <span class="badge rounded-pill text-bg-warning text-dark flex-shrink-0"><i class="bi bi-gem me-1"></i>Premium</span>
                        }
                    </div>
                    <div class="small text-muted d-flex flex-wrap gap-2">
                        <span class="badge bg-primary rounded-pill">@article.CategoryName</span>
                        <span><i class="bi bi-person me-1"></i>@article.AuthorName</span>
                        <span><i class="bi bi-calendar3 me-1"></i>@article.CreatedAt.ToString("MMM d, yyyy")</span>
                    </div>
                </article>
            }
        }
    </div>
</div>
