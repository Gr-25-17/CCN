@model List<NewsSite.Models.ViewModels.GoldViewModel>
@using System.Text.Json

@{
    var latest = Model.FirstOrDefault();
    
    // Determine visual styling based on price movement
    var isUp = latest != null && latest.IsUp;
    var priceColor = isUp ? "text-success" : "text-danger";
    var badgeBg = isUp ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger";
    var icon = isUp ? "bi-arrow-up-right-circle-fill" : "bi-arrow-down-right-circle-fill";
    
    // Fallback if change percentage isn't calculated in the viewmodel
    // (Assuming a standard percentage calculation if your model doesn't have it)
    var previousPrice = Model.Count > 1 ? Model[1].Price : latest?.Price ?? 1;
    var percentChange = latest != null ? ((latest.Price - previousPrice) / previousPrice) * 100 : 0;
}

<div class="card bg-dark text-white border-secondary shadow-lg overflow-hidden" style="max-width: 450px; border-radius: 12px;">
    <!-- Top Accent Bar matching the gold theme -->
    <div style="height: 4px; background: linear-gradient(90deg, #ffc107, #ff9800);"></div>
    
    <div class="card-body p-4">
        <!-- Header: Asset Name & Ticker -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
              @*   <span class="badge bg-warning text-dark fw-bold mb-1 px-2 py-1">COMMODITY</span> *@
                <h4 class="fw-bold mb-0">Gold Price</h4>
                <small class="text-muted fw-semibold">XAU / USD</small>
            </div>
            <div class="text-end">
                <span class="badge @badgeBg px-2 py-1 fs-6 d-inline-flex align-items-center gap-1">
                    <i class="bi @icon"></i>
                    @(percentChange >= 0 ? "+" : "")@percentChange.ToString("F2")%
                </span>
                <div class="small text-muted mt-1" style="font-size: 0.75rem;">
                    @latest?.DateLabel
                </div>
            </div>
        </div>

        <!-- Price Display Section -->
        <div class="border-bottom border-secondary pb-3 mb-4">
            <div class="d-flex align-items-baseline gap-2">
                <h1 class="display-5 fw-bold mb-0 tracking-tight text-white">
                    @latest?.Price.ToString("C")
                </h1>
                <span class="@priceColor fw-medium fs-5">
                    @(latest?.Change >= 0 ? "+" : "")@latest?.Change.ToString("N2")
                </span>
            </div>
        </div>

        <!-- Chart Container -->
        <div class="ratio ratio-16x9">
            <canvas id="goldChart"></canvas>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
    // Safe check for empty models
    const modelCount = @Model.Count;
    if (modelCount === 0) return;

    const labels = @Html.Raw(JsonSerializer.Serialize(Model.Select(x => x.DateLabel).Reverse()));
    const prices = @Html.Raw(JsonSerializer.Serialize(Model.Select(x => x.Price).Reverse()));
    const chartColor = '@(latest?.ChartColor ?? "#ffc107")';

    // Create a subtle gradient for the chart background area
    const ctx = document.getElementById('goldChart').getContext('2d');
    const gradient = ctx.createLinearGradient(0, 0, 0, 200);
    gradient.addColorStop(0, chartColor + '44'); // Transparent version of line color
    gradient.addColorStop(1, chartColor + '00'); // Fades to completely transparent

    new Chart(ctx, {
    type: 'line',
    data: {
    labels: labels,
    datasets: [{
    label: 'Price',
    data: prices,
    borderColor: chartColor,
    backgroundColor: gradient,
    fill: true,
    borderWidth: 2.5,
    tension: 0.25, // Smooth curves without looking unnatural
    pointRadius: 2,
    pointBackgroundColor: chartColor,
    pointBorderColor: 'transparent',
    pointHoverRadius: 6,
    pointHoverBackgroundColor: chartColor,
    pointHoverBorderColor: '#fff',
    pointHoverBorderWidth: 2
    }]
    },
    options: {
    maintainAspectRatio: false,
    plugins: {
    legend: { display: false },
    tooltip: {
    mode: 'index',
    intersect: false,
    backgroundColor: '#1f2327',
    titleColor: '#888',
    bodyColor: '#fff',
    borderColor: '#444',
    borderWidth: 1,
    padding: 10,
    displayColors: false
    }
    },
    scales: {
    x: {
    display: true,
    grid: { display: false },
    ticks: {
    color: '#6c757d',
    font: { size: 10 },
    maxRotation: 0,
    minRotation: 0,
    maxTicksLimit: 5 // Prevents horizontal crowding
    }
    },
    y: {
    display: true,
    grid: {
    color: '#2d3238',
    drawBorder: false
    },
    ticks: {
    color: '#6c757d',
    font: { size: 10 },
    maxTicksLimit: 4
    }
    }
    }
    }
    });
    });
</script>