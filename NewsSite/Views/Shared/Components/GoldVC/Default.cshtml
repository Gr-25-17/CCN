@model NewsSite.Models.ViewModels.MetalPricesPanelViewModel
@using System.Text.Json

@{
    var goldLatest = Model.GoldPrices.FirstOrDefault();

    var priceColor = goldLatest != null && goldLatest.IsUp ? "text-success" : "text-danger";
    var icon = goldLatest != null && goldLatest.IsUp ? "bi-arrow-up-right" : "bi-arrow-down-right";
    var shortDate = goldLatest?.DateLabel is { Length: > 0 }
        ? string.Join(" ", goldLatest.DateLabel.Split(' ').Take(2))
        : "--";
}

<div class="card bg-dark text-warning border-warning shadow-lg gold-price-card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <span class="badge rounded-pill text-bg-warning text-dark fw-semibold mb-2">Gold (XAU)</span>
                <h2 class="fw-bold mb-0 text-white">@goldLatest?.Price.ToString("C")</h2>
            </div>
            <div class="text-end">
                <div class="@priceColor fw-bold h5 mb-1">
                    <i class="bi @icon"></i> @goldLatest?.Change.ToString("N2")
                </div>
                <small class="text-muted">Gold update: @shortDate</small>
            </div>
        </div>

        <div class="bg-secondary bg-opacity-25 rounded p-2 mb-3">
            @foreach (var spotMetal in Model.SpotMetals)
            {
                var metal = spotMetal.Value;
                var metalColor = metal != null && metal.IsUp ? "text-success" : "text-danger";
                var metalIcon = metal != null && metal.IsUp ? "bi-arrow-up-right" : "bi-arrow-down-right";
                var symbol = spotMetal.Key switch
                {
                    "Silver" => "XAG",
                    "Platinum" => "XPT",
                    "Palladium" => "XPD",
                    _ => spotMetal.Key
                };

                <div class="d-flex justify-content-between align-items-center @(spotMetal.Equals(Model.SpotMetals.Last()) ? "" : "mb-2")">
                    <div class="small text-light fw-semibold">@spotMetal.Key (@symbol)</div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-white fw-bold">@metal?.Price.ToString("C")</span>
                        <span class="@metalColor small fw-semibold"><i class="bi @metalIcon"></i> @metal?.Change.ToString("N2")</span>
                    </div>
                </div>
            }
        </div>

        <div class="ratio ratio-16x9">
            <canvas id="goldChart"></canvas>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {

    const labels = @Html.Raw(JsonSerializer.Serialize(Model.GoldPrices.Select(x => x.DateLabel).Reverse()));
    const prices = @Html.Raw(JsonSerializer.Serialize(Model.GoldPrices.Select(x => x.Price).Reverse()));
    const chartColor = '@(goldLatest?.ChartColor ?? "#ffc107")';

    new Chart(document.getElementById('goldChart'), {
    type: 'line',
    data: {
    labels: labels,
    datasets: [{ label: 'Gold price',data: prices,borderColor: chartColor,
    backgroundColor: chartColor + '33',  fill: true,borderWidth: 2,tension: 0.3,
    pointRadius: 5,pointBackgroundColor: chartColor,pointBorderColor: '#fff',pointHoverRadius: 8
    }]
    },
    options: {
    maintainAspectRatio: false,
    plugins: {
    legend: { display: false }
    },
    scales: {
    x: {
    display: true,grid: { display: false },ticks: { color: '#888', maxRotation: 45, minRotation: 45 }
    },

    y: {
    display: true,
    grid: { color: '#333' },
    ticks: { color: '#888' }
    }
    }
    }
    });
    });
</script>
