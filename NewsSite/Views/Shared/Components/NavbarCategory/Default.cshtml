@model IEnumerable<NewsSite.Models.ViewModels.CategoryViewModel>
@{
    var currentSlug = Context.Request.Query["slug"].ToString();
}

@foreach (var category in Model)
{
    var isActiveCategory = string.Equals(currentSlug, category.Name, StringComparison.OrdinalIgnoreCase);
    <li class="nav-item">
        <a class="nav-link text-dark"
           asp-controller="Category"
           asp-action="Index"
           asp-route-slug="@category.Name"
           aria-current="@(isActiveCategory ? "page" : null)">
            @category.Name
        </a>
    </li>
}
