@using Microsoft.AspNetCore.Identity
@using NewsSite.Models.Entities
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService

@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var isAdmin = isAuthenticated && User.IsInRole("Admin");
    var canAccessWriterPanel = (await AuthorizationService.AuthorizeAsync(User, "ManagementOnly")).Succeeded;
    var showManagementDropdown = isAdmin && canAccessWriterPanel;
}

<ul class="navbar-nav">
    @if (showManagementDropdown)
    {
        <li class="nav-item dropdown d-none d-lg-block">
            <a class="nav-link dropdown-toggle text-dark" href="#" id="managementMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                Paneler
            </a>
            <ul class="dropdown-menu" aria-labelledby="managementMenu">
                <li>
                    <a class="dropdown-item" asp-area="" asp-controller="Admin" asp-action="Index">Admin Dashboard</a>
                </li>
                <li>
                    <a class="dropdown-item" asp-area="" asp-controller="Writer" asp-action="Index">Skribent</a>
                </li>
                <li>
                    <a class="dropdown-item" asp-controller="SubscriptionAnalytics" asp-action="Index">📊Analytics</a>
                </li>
            </ul>
        </li>
        <li class="nav-item d-lg-none">
            <a class="nav-link text-dark" asp-area="" asp-controller="Admin" asp-action="Index">Admin Dashboard</a>
        </li>
        <li class="nav-item d-lg-none">
            <a class="nav-link text-dark" asp-area="" asp-controller="Writer" asp-action="Index">Skribent</a>
        </li>
        <li class="nav-item d-lg-none">
            <a class="nav-link text-dark" asp-controller="SubscriptionAnalytics" asp-action="Index">📊 Analytics</a>
        </li>
    }
    else if (canAccessWriterPanel)
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="" asp-controller="Writer" asp-action="Index">Skribent</a>
        </li>
    }

    @if (SignInManager.IsSignedIn(User))
    {
        var hasSubscription = (await AuthorizationService.AuthorizeAsync(User, "PremiumContent")).Succeeded;

        if (hasSubscription)
        {
            <li class="nav-item d-lg-none">
                <a class="nav-link text-dark" asp-controller="Game" asp-action="Index">Panchinko</a>
            </li>
        }
        
        <li class="nav-item">
            <a class="nav-link text-dark fw-bold" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                Hello @((await UserManager.GetUserAsync(User))?.FirstName ?? User.Identity?.Name)
                @if (hasSubscription)
                {
                    <text>💎</text>
                }
                else
                {
                    <text>⬜</text>
                }
            </a>
        </li>
        <li class="nav-item">
            <form id="logoutForm"
                  class="form-inline"
                  asp-area="Identity"
                  asp-page="/Account/Logout"
                  data-ajax-logout="true">
                @Html.AntiForgeryToken()
                <button type="button" class="nav-link btn btn-link text-dark" data-logout-button="true">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <button type="button" class="nav-link btn btn-link text-dark border-0" data-bs-toggle="offcanvas" data-bs-target="#loginOffcanvas" data-auth-mode="register">Register</button>
        </li>
        <li class="nav-item">
            <button type="button" class="nav-link btn btn-link text-dark border-0" data-bs-toggle="offcanvas" data-bs-target="#loginOffcanvas" data-auth-mode="login">Login</button>
        </li>
    }
</ul>