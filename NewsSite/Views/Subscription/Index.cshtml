@using NewsSite.Models.ViewModels
@model PaymentViewModel

<h2>Subscribe</h2>

<form asp-controller="Subscription" asp-action="Index" method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="All" class="text-danger"></div>

    <input asp-for="ReturnUrl" type="hidden" />

    <div class="mb-3">
        <label asp-for="CardName"></label>
        <input asp-for="CardName" class="form-control" />
        <span asp-validation-for="CardName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CardNumber"></label>
        <input asp-for="CardNumber" class="form-control" placeholder="1234567812345678" />
        <span asp-validation-for="CardNumber" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ExpirationDate"></label>
        <input asp-for="ExpirationDate" class="form-control" placeholder="MM/YY" />
        <span asp-validation-for="ExpirationDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CVV"></label>
        <input asp-for="CVV" class="form-control" placeholder="123" />
        <span asp-validation-for="CVV" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Pay Now</button>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
