@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-6">
        <form id="profile-form" method="post">
            <div class="form-group mb-3">
                <label asp-for="Input.FirstName" class="form-label"></label>
                <input asp-for="Input.FirstName" class="form-control" />
                <span asp-validation-for="Input.FirstName" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Input.LastName" class="form-label"></label>
                <input asp-for="Input.LastName" class="form-control" />
                <span asp-validation-for="Input.LastName" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Input.DateOfBirth" class="form-label"></label>
                <input asp-for="Input.DateOfBirth" class="form-control" type="date" />
                <span asp-validation-for="Input.DateOfBirth" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Input.PhoneNumber" class="form-label"></label>
                <input asp-for="Input.PhoneNumber" class="form-control" />
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>

           
            <div class="form-group mb-3">
                <label class="form-label fw-bold">Prefered Categorys</label>
                <div class="row">
                    @foreach (var category in Model.ContentPreferences.AvailableCategories)
                    {
                        <div class="col-6 col-md-4 mb-2">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input"
                                       name="ContentPreferences.SelectedCategoryIds"
                                       value="@category.Id"
                                @(Model.ContentPreferences.SelectedCategoryIdsList.Contains(category.Id) ? "checked" : "") />
                                <label class="form-check-label">@category.Name</label>
                            </div>
                        </div>
                    }
                </div>
            </div>

            
            <div class="form-group mb-3">
                <label class="form-label fw-bold">Favorite Authors</label>
                <div class="row">
                    @foreach (var author in Model.ContentPreferences.AvailableAuthors)
                    {
                        <div class="col-6 col-md-4 mb-2">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input"
                                       name="ContentPreferences.SelectedAuthorIds"
                                       value="@author.Id"
                                @(Model.ContentPreferences.SelectedAuthorIdsList.Contains(author.Id) ? "checked" : "") />
                                <label class="form-check-label">
                                    @author.Name
                                    @if (author.ArticleCount > 0)
                                    {
                                        <small class="text-muted">(@author.ArticleCount)</small>
                                    }
                                </label>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Spara profil</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}